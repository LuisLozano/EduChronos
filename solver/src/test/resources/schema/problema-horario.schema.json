{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yaroki.es/educhronos/problema-horario.schema.json",
  "title": "ProblemaHorario",
  "type": "object",
  "additionalProperties": false,
  "required": ["tramos", "aulas", "asignaturas", "profesores", "grupos", "subgrupos", "actividades"],
  "properties": {
    "tramos":      { "type": "array", "items": { "$ref": "#/$defs/tramo" } },
    "aulas":       { "type": "array", "items": { "$ref": "#/$defs/aula" } },
    "asignaturas": { "type": "array", "items": { "$ref": "#/$defs/asignatura" } },
    "profesores":  { "type": "array", "items": { "$ref": "#/$defs/profesor" } },
    "grupos":      { "type": "array", "items": { "$ref": "#/$defs/grupo" } },
    "subgrupos":   { "type": "array", "items": { "$ref": "#/$defs/subgrupo" } },
    "actividades": { "type": "array", "items": { "$ref": "#/$defs/actividad" } }
  },
  "$defs": {
    "tramo": {
      "type": "object", "additionalProperties": false,
      "required": ["codigo", "diaSemana", "ordenEnDia"],
      "properties": {
        "codigo":     { "type": "string", "minLength": 1 },
        "diaSemana":  { "type": "integer", "minimum": 1, "maximum": 5 },
        "ordenEnDia": { "type": "integer", "minimum": 1, "maximum": 6 }
      }
    },
    "aula": {
      "type": "object", "additionalProperties": false,
      "required": ["codigo", "nombre"],
      "properties": { "codigo": { "type": "string", "minLength": 1 }, "nombre": { "type": "string" } }
    },
    "asignatura": {
      "type": "object", "additionalProperties": false,
      "required": ["codigo", "nombre"],
      "properties": { "codigo": { "type": "string", "minLength": 1 }, "nombre": { "type": "string" } }
    },
    "profesor": {
      "type": "object", "additionalProperties": false,
      "required": ["codigo", "nombre"],
      "properties": { "codigo": { "type": "string", "minLength": 1 }, "nombre": { "type": "string" } }
    },
    "grupo": {
      "type": "object", "additionalProperties": false,
      "required": ["codigo", "tipo"],
      "properties": {
        "codigo":     { "type": "string", "minLength": 1 },
        "tipo":       { "enum": ["ORDINARIO", "DIVERSIFICACION_PDC"] },
        "grupoPadre": { "type": ["string", "null"] }
      }
    },
    "subgrupo": {
      "type": "object", "additionalProperties": false,
      "required": ["codigo", "grupos"],
      "properties": {
        "codigo": { "type": "string", "minLength": 1 },
        "grupos": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "actividad": {
      "type": "object", "additionalProperties": false,
      "required": ["codigo", "repeticionesPorSemana", "duracionTramos", "patronTemporal", "plazas"],
      "properties": {
        "codigo":                { "type": "string", "minLength": 1 },
        "asignatura":            { "type": ["string", "null"] },
        "repeticionesPorSemana": { "type": "integer", "minimum": 1 },
        "duracionTramos":        { "type": "integer", "minimum": 1 },
        "patronTemporal":        { "enum": ["DISTRIBUIDA", "AGRUPADA", "NEUTRA"] },
        "plazas":                { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/plaza" } }
      }
    },
    "plaza": {
      "type": "object", "additionalProperties": false,
      "required": ["codigo", "asignatura", "profesores", "subgrupos"],
      "properties": {
        "codigo":          { "type": "string", "minLength": 1 },
        "asignatura":      { "type": "string", "minLength": 1 },
        "profesores":      { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "aulaFija":        { "type": ["string", "null"] },
        "aulasCandidatas": { "type": "array", "items": { "type": "string" } },
        "subgrupos":       { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    }
  }
}
